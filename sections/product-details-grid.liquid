{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="product-details-grid color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width page-width--narrow">
    {%- if section.settings.title != blank -%}
      <div class="product-details-grid__header center">
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="product-details-grid__container">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'detail_item' -%}
            <div class="product-details-grid__row" {{ block.shopify_attributes }}>
              <div class="product-details-grid__key caption-with-letter-spacing">
                {{ block.settings.key | escape }}
              </div>
              <div class="product-details-grid__value rte">
                {{ block.settings.value }}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .product-details-grid__header {
    margin-bottom: 4rem;
  }

  .product-details-grid__container {
    display: flex;
    flex-direction: column;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.1);
  }

  .product-details-grid__row {
    display: flex;
    flex-direction: column;
    padding: 2.5rem 0;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
  }

  @media screen and (min-width: 750px) {
    .product-details-grid__row {
      flex-direction: row;
      align-items: baseline;
    }
  }

  .product-details-grid__key {
    color: rgba(var(--color-foreground), 0.75);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .product-details-grid__key {
      width: 35%;
      margin-bottom: 0;
      padding-right: 4rem;
    }
  }

  .product-details-grid__value {
    flex: 1;
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
  }

  .product-details-grid__value p {
    margin: 0;
  }

  .product-details-grid__value p + p {
    margin-top: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Details Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Product Details",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "detail_item",
      "name": "Detail entry",
      "settings": [
        {
          "type": "text",
          "id": "key",
          "label": "Key",
          "default": "Detail label"
        },
        {
          "type": "richtext",
          "id": "value",
          "label": "Value",
          "default": "<p>Detail value mapped to metafield</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Details Grid",
      "blocks": [
        {
          "type": "detail_item"
        },
        {
          "type": "detail_item"
        },
        {
          "type": "detail_item"
        }
      ]
    }
  ]
}
{% endschema %}
